{
  "name": "puzzle-engine",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "拼图引擎 - 基于 Bun + Elysia + React 的 monorepo 项目",
  "author": "18267094443@163.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/puzzle-fuzzy/puzzle-engine.git"
  },
  "module": "index.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "kill-ports": "bun run scripts/kill-ports.ts",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:client": "bun run --cwd apps/client dev",
    "dev": "bun run kill-ports && concurrently \"bun run dev:server\" \"bun run dev:client\" --names \"SERVER,CLIENT\" --prefix-colors \"bgBlue.bold,bgGreen.bold\" --kill-others-on-fail"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.8.17",
    "@types/bun": "latest",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-refresh": "^0.5.2"
  }
}
