# ============================================================
# 环境变量模板
# 复制为 .env 后填入实际值：cp .env.example .env
# ============================================================

# ----- PostgreSQL（必填） -----
# Docker: docker compose up -d 后默认可用以下连接串
DATABASE_URL=postgres://excuse:excuse_dev@localhost:5433/excuse

# ----- 阿里云 DashScope（必填） -----
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ----- JWT 认证（必填） -----
# 生产环境请使用 >= 32 字符的随机字符串
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ----- 服务配置（可选，已提供默认值） -----
NODE_ENV=development
PORT=5007
FRONTEND_URL=http://localhost:8007
STORAGE_ROOT=./uploads

# ----- Worker 配置（可选） -----
WORKER_POLL_INTERVAL_MS=5000
WORKER_STALE_TIMEOUT_MS=14400000

# ----- 日志级别（可选，默认根据 NODE_ENV 自动选择） -----
# LOG_LEVEL=debug

# ----- 阿里云 OSS（可选，不配置则使用本地文件存储） -----
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=
# OSS_UPLOAD_PREFIX=uploads
# OSS_GENERATED_PREFIX=generated

# ----- 前端（可选，Vite 客户端通过代理访问后端） -----
# VITE_API_BASE_URL=http://localhost:5007

